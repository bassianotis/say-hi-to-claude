# Timezone for the 6am cron trigger. Use an IANA zone name
# (e.g. UTC, Europe/London, America/New_York, Asia/Tokyo).
TZ=UTC

# Host path for the work-account Claude Code auth state.
# Must not overlap with any other Claude auth directory on this machine.
CLAUDE_WORK_AUTH=./claude-auth

# Optional: webhook URL for ping-failure notifications. Leave empty to disable.
# (Not yet wired up — placeholder for a future Slack Incoming Webhook.)
NOTIFY_URL=

# Used by `make deploy` from your dev machine. Leave blank on the target machine.
PI_HOST=
PI_PATH=
